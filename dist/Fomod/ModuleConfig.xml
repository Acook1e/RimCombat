<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://qconsulting.ca/fo3/ModConfig5.0.xsd">

    <moduleName>Rim Combat</moduleName>

    <installSteps order="Explicit">
        <installStep name="">
            <optionalFileGroups order="Explicit">
                <group name="Main Files / 主要文件" type="SelectExactlyOne">
                    <plugins order="Explicit">
                        <plugin name="Core Files / 核心文件">
                            <description></description>
                            <files>
                                <folder source="Core" destination="" />
                            </files>
                            <typeDescriptor>
                                <type name="Required" />
                            </typeDescriptor>
                        </plugin>
                    </plugins>
                </group>
                <group name="Install Language / 安装语言" type="SelectExactlyOne">
                    <plugins order="Explicit">
                        <plugin name="English">
                            <description>English language files</description>
                            <files>
                                <folder source="English" destination="" />
                            </files>
                            <typeDescriptor>
                                <type name="Optional" />
                            </typeDescriptor>
                        </plugin>
                        <plugin name="简体中文">
                            <description>简体中文语言文件</description>
                            <files>
                                <folder source="Chinese" destination="" />
                            </files>
                            <typeDescriptor>
                                <type name="Optional" />
                            </typeDescriptor>
                        </plugin>
                    </plugins>
                </group>
            </optionalFileGroups>
        </installStep>
    </installSteps>

</config>